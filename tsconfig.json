{
  "compilerOptions": {

    "target": "ES2020",

    "module": "CommonJS",

    "moduleResolution": "node",

    "strict": true,

    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "outDir": "dist",

    "rootDir": "src",

    "baseUrl": "./",

    "ignoreDeprecations": "6.0",

    "paths": {
      "@/*": [
        "src/*"
      ]
    }

  },

  "include": [
    "src/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}